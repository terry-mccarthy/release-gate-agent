# Copy to .env and fill in values before running the stack

# Required
VALIDATOR_SECRET=validator-secret

# JWT signing key — change in production
JWT_SECRET=dev-jwt-secret-change-in-prod

# LLM provider: "ollama" (default, local) or "gemini"
LLM_PROVIDER=ollama

# Ollama settings (if LLM_PROVIDER=ollama)
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_NUM_CTX=8192

# Gemini settings (if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Shared LLM settings
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Coverage stub default (overridden per-call via # COVERAGE:<pct> in diff)
STUB_COVERAGE_PCT=91.0

# Logging
LOG_LEVEL=INFO
